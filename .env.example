# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ---------- IntelliDesk 数据源（二选一）----------
#
# 【正式环境看不到数据库里的工单？】
# 1) 构建产物必须带 VITE_API_BASE_URL=你的 HTTPS API 根地址，否则前端仍用内置 mock。
# 2) 建议显式 VITE_INTELLIDESK_DATA_SOURCE=api。
# 3) 后端正式库：生产骨架 npm run db:deploy:production；全量演示数据 npm run db:deploy（均在 backend 目录）。
# 4) X-Tenant-Id / VITE_INTELLIDESK_TENANT_ID 须与灌库用的租户一致（默认同 prisma seed）。
#
# mock：强制演示数据，忽略 VITE_API_BASE_URL（npm run dev / dev:mock → 本机 :3000）
# api：须设置 VITE_API_BASE_URL（npm run dev:api / dev:live → 本机 :4000，开发时由 Vite 代理到后端 :4001）
# 不设 VITE_INTELLIDESK_DATA_SOURCE 时：有 API 地址则联调，无则 mock（与旧行为一致）
# VITE_INTELLIDESK_DATA_SOURCE=mock
# VITE_INTELLIDESK_DATA_SOURCE=api
# VITE_API_BASE_URL=http://localhost:4000
# 可选；不设则与 backend/prisma/seed 默认租户一致
# VITE_INTELLIDESK_TENANT_ID=11111111-1111-4111-8111-111111111111
# 可选；不设则联调时使用 seed 的 admin UUID 作为 X-User-Id（演示）
# VITE_INTELLIDESK_USER_ID=22222222-2222-4222-8222-222222222222
# 勿把母系统 Bearer Token 写进前端环境变量。
#
# 本地仅两个开发端口：3000（mock）、4000（联调 UI，同源代理 /api 与 /ws 至后端 4001）
#      npm run dev / dev:mock → :3000 + mode mock
#      npm run dev:api / dev:live → :4000 + mode api（先另开终端 backend: npm run dev）
#      preview:mock / preview:api → 均为 :4173，按构建 mode 区分数据源
