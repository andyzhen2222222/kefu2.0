DATABASE_URL="postgresql://intellidesk:intellidesk@localhost:5433/intellidesk?schema=public"
PORT=4000
# JSON 响应已启用 gzip（compression），大工单详情传输体积更小
# 单租户时可设默认租户 UUID，请求可省略 X-Tenant-Id（与 prisma seed 一致）
# DEFAULT_TENANT_ID=11111111-1111-4111-8111-111111111111
# 生产环境若需沿用前端「账号框 + POST /api/auth/session-from-account」联调登录，需显式开启：
# ALLOW_ACCOUNT_SESSION=1
# 母系统 HTTP 超时（毫秒），同步大量订单/消息时适当加大
# MOTHER_FETCH_TIMEOUT_MS=120000
# 可选：母系统订单回源（服务端）
NEZHA_API_BASE=https://tiaojia.nezhachuhai.com
NEZHA_API_TOKEN=
# 可选：覆盖母系统根 URL（未设时与 NEZHA_API_BASE 相同）
# MOTHER_SYSTEM_API_URL=
# 打开工单时是否在后台异步补全缺失的 orderId/消息（不阻塞首包，需 NEZHA_API_TOKEN）：默认开启；设为 0 关闭
# TICKET_DETAIL_NEZHA_HYDRATE=0
# 订单关键词回源 fetchNezhaOrderHint 超时（毫秒），防止母系统慢时阻塞接口
# NEZHA_ORDER_HINT_TIMEOUT_MS=8000
# 工单详情单次返回的最近消息条数上限（过大拖慢 DB/JSON）；可用查询参数 messagesLimit 覆盖，最大 2000
# TICKET_DETAIL_MESSAGES_LIMIT=500
# 详情里订单物流轨迹条数上限（与 mapOrder 排序一致，取 sortIndex/timestamp 较新的若干条）
# TICKET_DETAIL_LOGISTICS_EVENTS_LIMIT=120
# 设置后，POST /api/sync/mother-system、/api/sync/inbox-tickets、/api/sync/invoice-entities
# 可在 JSON 中省略 token 字段，服务端自动使用该变量。
#
# 定时增量同步（进程内 setInterval）：需 NEZHA_API_TOKEN，且租户「系统同步」中 syncEnabled 为 true
# SYNC_SCHEDULER_ENABLED=1
# SYNC_SCHEDULER_TICK_MS=20000
# 母系统同步店铺时（POST /api/sync/mother-system）会额外请求 /v1/api/biz/platform-site/all，
# 将站点默认货币、平台语言写入 Channel（需与 auth-platform-shop 的店铺 id 对齐）。
# 另会请求 /v1/automation/ecommerce/auth-platform-shop 与 /v1/api/ecommerce/vat-info/page，
# 合并主体+VAT 写入 Channel.invoiceStoreEntity（发票侧栏 / 预览用）。
# AI（仅服务端）：火山方舟豆包（与官方快速入门一致）
# https://www.volcengine.com/docs/82379/2272060
# API Key：控制台「API Key 管理」创建，与 curl Authorization Bearer 一致（任填其一）
ARK_API_KEY=
DOUBAO_API_KEY=
#
# 17track API
TRACK17_API_TOKEN=
#
# 模型标识（二选一，须在控制台开通对应模型）：
# - Chat Completions：推理接入点 ID，形如 ep-xxxx（存量/接入点场景）
# - Responses API：官方示例模型名，如 doubao-seed-2-0-lite-260215（新用户推荐）
DOUBAO_ENDPOINT_ID=
# 可选，显式覆盖 DOUBAO_ENDPOINT_ID
# DOUBAO_MODEL_ID=
# 可选，默认 https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_BASE_URL=
# Responses API：是否启用深度思考。默认 disabled（与文档 thinking.type=disabled 一致，降低延迟）
# 需要思考链时设为：ARK_THINKING=enabled
# ARK_THINKING=disabled
# DOUBAO_THINKING=disabled
# 可选：强制 responses | chat（不设则 ep- 走 chat，否则走 responses）
# DOUBAO_API_MODE=
# 兼容别名：ARK_MODEL_ID / ARK_ENDPOINT_ID / ARK_BASE_URL / ARK_API_MODE
# 未配置豆包时回退 Gemini
GEMINI_API_KEY=
# 可选，默认 gemini-2.0-flash
# GEMINI_MODEL=
# 可选：Redis（AI 限流等多实例一致）；未配置时使用进程内回退
REDIS_URL=
# 设置后与 Authorization: Bearer <Firebase ID Token> 联用，按 email 匹配租户内 User，覆盖 X-User-Id
FIREBASE_PROJECT_ID=
# 设为 1 时工单列表 search 额外使用 pg_trgm similarity（需已执行 prisma 迁移启用扩展）
PG_TRGM_SEARCH=
#
# AI 回归（仓库根目录）：npm run test:ai；直连后端：API_BASE=http://127.0.0.1:4000；经 Vite：API_BASE=http://localhost:4001
# 严格模式（须已配置方舟/Gemini）：STRICT_AI=1 npm run test:ai
