DATABASE_URL="postgresql://intellidesk:intellidesk@localhost:5433/intellidesk?schema=public"
PORT=4001
# 可选：母系统订单回源（服务端）
NEZHA_API_BASE=https://tiaojia.nezhachuhai.com
NEZHA_API_TOKEN=
# AI 代理（仅服务端）
GEMINI_API_KEY=
# 可选：Redis（AI 限流等多实例一致）；未配置时使用进程内回退
REDIS_URL=
# 设置后与 Authorization: Bearer <Firebase ID Token> 联用，按 email 匹配租户内 User，覆盖 X-User-Id
FIREBASE_PROJECT_ID=
# 设为 1 时工单列表 search 额外使用 pg_trgm similarity（需已执行 prisma 迁移启用扩展）
PG_TRGM_SEARCH=
