{
  "name": "intellidesk-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:deploy": "prisma migrate deploy && prisma db seed",
    "db:deploy:production": "prisma migrate deploy && tsx prisma/seed-production.ts",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:production": "tsx prisma/seed-production.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@prisma/client": "^6.3.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jose": "^6.2.2",
    "redis": "^4.7.0",
    "uuid": "^11.0.5",
    "ws": "^8.18.0",
    "zod": "^3.24.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.15",
    "@types/ws": "^8.5.14",
    "prisma": "^6.3.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
