{
  "description": "前端 intellideskApi.ts 与 backend 路由对照（工单界面联调）",
  "headers": {
    "X-Tenant-Id": "11111111-1111-4111-8111-111111111111",
    "X-User-Id": "22222222-2222-4222-8222-222222222222",
    "Content-Type": "application/json"
  },
  "routes": [
    { "function": "fetchTicketsList", "method": "GET", "path": "/api/tickets", "backend": "backend/src/routes/tickets.ts" },
    { "function": "fetchTicketDetail", "method": "GET", "path": "/api/tickets/:id", "backend": "backend/src/routes/tickets.ts" },
    { "function": "fetchTicketMessagesPage", "method": "GET", "path": "/api/tickets/:id/messages", "backend": "backend/src/routes/tickets.ts" },
    { "function": "patchTicket", "method": "PATCH", "path": "/api/tickets/:id", "backend": "backend/src/routes/tickets.ts" },
    { "function": "postTicketMessage", "method": "POST", "path": "/api/tickets/:id/messages", "backend": "backend/src/routes/tickets.ts" },
    { "function": "patchTicketMessage", "method": "PATCH", "path": "/api/tickets/:id/messages/:messageId", "backend": "backend/src/routes/tickets.ts" },
    { "function": "deleteTicketMessage", "method": "DELETE", "path": "/api/tickets/:id/messages/:messageId", "backend": "backend/src/routes/tickets.ts" },
    { "function": "fetchAgentSeats", "method": "GET", "path": "/api/settings/agent-seats", "backend": "backend/src/routes/settings.ts" },
    { "function": "fetchOrderDetail", "method": "GET", "path": "/api/orders/:id", "backend": "backend/src/routes/orders.ts" },
    { "function": "fetchOrderByPlatformOrderId", "method": "GET", "path": "/api/orders?platformOrderId=", "backend": "backend/src/routes/orders.ts" },
    { "function": "fetchAfterSalesList", "method": "GET", "path": "/api/after-sales", "backend": "backend/src/routes/afterSales.ts" },
    { "function": "createAfterSalesRecord", "method": "POST", "path": "/api/after-sales", "backend": "backend/src/routes/afterSales.ts" },
    { "function": "postInboxTicketsSync", "method": "POST", "path": "/api/sync/inbox-tickets", "backend": "backend/src/routes/sync.ts" },
    { "function": "postAiSuggestReply", "method": "POST", "path": "/api/ai/suggest-reply", "backend": "backend/src/routes/ai.ts" },
    { "function": "postAiClassifyIntent", "method": "POST", "path": "/api/ai/classify-intent", "backend": "backend/src/routes/ai.ts" },
    { "function": "postAiClassifySentiment", "method": "POST", "path": "/api/ai/classify-sentiment", "backend": "backend/src/routes/ai.ts" },
    { "function": "postAiTranslate", "method": "POST", "path": "/api/ai/translate", "backend": "backend/src/routes/ai.ts" },
    { "function": "intellideskWsUrl", "method": "WebSocket", "path": "/ws?tenantId=", "backend": "backend/src/lib/wsHub.ts" }
  ]
}
